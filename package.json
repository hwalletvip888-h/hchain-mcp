{
  "name": "hchain-mcp",
  "version": "1.1.0",
  "description": "hchain-mcp — AI-native multi-chain trading MCP Server, 99 tools over HTTP & stdio",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "hchain-mcp": "dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hwalletvip888-h/hchain-mcp.git"
  },
  "homepage": "https://github.com/hwalletvip888-h/hchain-mcp#readme",
  "bugs": {
    "url": "https://github.com/hwalletvip888-h/hchain-mcp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "onchainos",
    "okx",
    "web3",
    "crypto",
    "trading",
    "multi-chain",
    "ai-agent",
    "blockchain"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
