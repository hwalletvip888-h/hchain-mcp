{
  "name": "hchain-skills",
  "version": "1.5.0",
  "description": "hchain-skills — AI-native multi-chain trading MCP Server (116 tools / 18 composite skills, beyond official OnchainOS) — production-hardened",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "hchain-skills": "dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hwalletvip888-h/hchain-mcp.git"
  },
  "homepage": "https://github.com/hwalletvip888-h/hchain-mcp#readme",
  "bugs": {
    "url": "https://github.com/hwalletvip888-h/hchain-mcp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "onchainos",
    "okx",
    "defi",
    "dex",
    "swap",
    "cross-chain",
    "solana",
    "ethereum",
    "web3",
    "crypto",
    "trading",
    "multi-chain",
    "ai-agent",
    "blockchain"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepublishOnly": "npm run build",
    "version": "git add -A src package.json package-lock.json",
    "postversion": "git push && git push --tags"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "dotenv": "^17.4.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.1.0",
    "eslint": "^9.0.0",
    "prettier": "^3.5.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.1.0"
  }
}
